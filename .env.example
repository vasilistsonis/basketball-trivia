# ── Baked into the app at build time (safe to expose; anon key is public by design) ──
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Used ONLY by `npm run seed` (server/seed.ts). NEVER prefixed with VITE_,
#    never shipped, never committed. Rotate immediately if it ever leaks. ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-seeding-only
